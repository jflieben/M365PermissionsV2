                <span class="page-info">Page ${userLookupPage} of ${totalPages}</span>
                <button ${userLookupPage >= totalPages ? 'disabled' : ''} onclick="window.m365.searchUserPerms(${userLookupPage + 1})">Next →</button>
            ` : '';
        } catch (e) {
